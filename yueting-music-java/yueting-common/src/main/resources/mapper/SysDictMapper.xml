<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yueting.common.mapper.SysDictMapper">
  <resultMap id="BaseResultMap" type="com.yueting.entity.po.SysDict">
    <id column="id" property="id"/>
    <result column="parent_id" property="parentId"/><result column="dict_name" property="dictName"/>
    <result column="dict_code" property="dictCode"/><result column="dict_label" property="dictLabel"/>
    <result column="dict_value" property="dictValue"/><result column="status" property="status"/>
    <result column="remark" property="remark"/><result column="sort_order" property="sortOrder"/>
  </resultMap>
  <sql id="BaseColumns">id,parent_id,dict_name,dict_code,dict_label,dict_value,status,remark,sort_order</sql>
  <select id="selectList" resultMap="BaseResultMap">
    SELECT <include refid="BaseColumns"/> FROM sys_dict
    <where>
      <if test="dictName != null and dictName != ''">AND dict_name LIKE CONCAT('%',#{dictName},'%')</if>
      <if test="dictCode != null and dictCode != ''">AND dict_code LIKE CONCAT('%',#{dictCode},'%')</if>
      <if test="dictLabel != null and dictLabel != ''">AND dict_label LIKE CONCAT('%',#{dictLabel},'%')</if>
      <if test="status != null">AND status = #{status}</if>
    </where> ORDER BY sort_order ASC, id ASC
  </select>
  <select id="selectById" resultMap="BaseResultMap">SELECT <include refid="BaseColumns"/> FROM sys_dict WHERE id = #{id}</select>
  <select id="selectByParentId" resultMap="BaseResultMap">SELECT <include refid="BaseColumns"/> FROM sys_dict WHERE parent_id = #{parentId} ORDER BY sort_order ASC, id ASC</select>
  <select id="selectByCode" resultMap="BaseResultMap">SELECT <include refid="BaseColumns"/> FROM sys_dict WHERE dict_code = #{dictCode}</select>
  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO sys_dict (parent_id,dict_name,dict_code,dict_label,dict_value,status,remark,sort_order)
    VALUES (#{parentId},#{dictName},#{dictCode},#{dictLabel},#{dictValue},#{status},#{remark},#{sortOrder})
  </insert>
  <update id="update">
    UPDATE sys_dict <set>
      <if test="parentId != null">parent_id = #{parentId},</if>
      <if test="dictName != null">dict_name = #{dictName},</if>
      <if test="dictCode != null">dict_code = #{dictCode},</if>
      <if test="dictLabel != null">dict_label = #{dictLabel},</if>
      <if test="dictValue != null">dict_value = #{dictValue},</if>
      <if test="status != null">status = #{status},</if>
      <if test="remark != null">remark = #{remark},</if>
      <if test="sortOrder != null">sort_order = #{sortOrder},</if>
    </set> WHERE id = #{id}
  </update>
  <delete id="deleteById">DELETE FROM sys_dict WHERE id = #{id}</delete>
  <select id="countByParentId" resultType="int">SELECT COUNT(*) FROM sys_dict WHERE parent_id = #{parentId}</select>
</mapper>